        "# Cell 1: Import necessary libraries\n",
        "import yfinance as yf\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy.optimize import minimize\n",
        "\n",
        "# Define the assets you want to analyze\n",
        "# We'll use a mix of Tech, Retail, and a safe asset (Gold)\n",
        "tickers = ['AAPL', 'MSFT', 'AMZN', 'GLD']\n",
        "\n",
        "# Download historical data from Yahoo Finance\n",
        "data = yf.download(tickers, start=\"2021-01-01\", end=\"2026-06-01\")['Close']\n",
        "\n",
        "# Show the first 5 rows to verify the data is loaded\n",
        "print(data.head())"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Calculate daily returns (percentage change)\n",
        "returns = data.pct_change().dropna()\n",
        "\n",
        "# Calculate the mean daily returns and the covariance matrix\n",
        "# This matrix represents how each asset moves in relation to the others\n",
        "mean_returns = returns.mean()\n",
        "cov_matrix = returns.cov()\n",
        "\n",
        "print(\"Mean Daily Returns:\")\n",
        "print(mean_returns)\n",
        "print(\"\\nCovariance Matrix:\")\n",
        "print(cov_matrix)\n"
      ],
